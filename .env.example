# =============================================================
# MinIO (S3-compatible Object Storage)
# =============================================================
MINIO_ROOT_USER=your-minio-user
MINIO_ROOT_PASSWORD=your-minio-password

# =============================================================
# Kafka
# =============================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# =============================================================
# ClickHouse
# =============================================================
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password

# =============================================================
# PostgreSQL (Airflow metadata database)
# =============================================================
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=airflow

# =============================================================
# Airflow
# =============================================================
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=your-airflow-password
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__WEBSERVER__SECRET_KEY=your-webserver-secret-key
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:your-postgres-password@postgres/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:your-postgres-password@postgres/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__CORE__LOAD_EXAMPLES=false

# =============================================================
# Superset
# =============================================================
SUPERSET_SECRET_KEY=your-superset-secret-key

# =============================================================
# Iceberg REST Catalog
# =============================================================
ICEBERG_REST_PORT=8181
AWS_ACCESS_KEY_ID=your-s3-access-key
AWS_SECRET_ACCESS_KEY=your-s3-secret-key
AWS_REGION=us-east-1
